{
  "id": "navy-single-column",
  "name": "Navy Single Column",
  "version": "1.0.0",
  "description": "House style for the HireTrack resume builder: single-column, ATS-safe, Calibri body, navy section headers with right-tabbed dates. Consumed by both the DOCX and PDF renderers in src/lib/resumeRender.ts and by the Track 3 visual-QA loop.",
  "fonts": {
    "primary": "Calibri",
    "fallback": "Carlito, Helvetica, Arial",
    "pdfSubstitute": "Helvetica"
  },
  "page": {
    "size": "Letter",
    "widthTwips": 12240,
    "heightTwips": 15840,
    "marginInches": 0.75,
    "marginTwips": 1080,
    "contentWidthTwips": 10080
  },
  "colors": {
    "sectionHeader": "1F3864",
    "link": "2E5395",
    "body": "1a1a1a"
  },
  "sectionHeader": {
    "allCaps": true,
    "bottomBorder": true,
    "datesRightAligned": true,
    "tabRightTwips": 10080
  },
  "bullets": {
    "boldLeadIn": true
  },
  "pagination": {
    "keepNextOnJobHeader": true
  },
  "spacing": {
    "bulletAfter": 60,
    "bulletLine": 252,
    "sectionBefore": 200,
    "jobBefore": 140
  },
  "overflowLevers": [
    {
      "id": "bulletAfter",
      "target": "bullet",
      "property": "spacing.after",
      "steps": [60, 40, 32]
    },
    {
      "id": "bulletLine",
      "target": "bullet",
      "property": "spacing.line",
      "steps": [252, 240, 232]
    },
    {
      "id": "sectionBefore",
      "target": "sectionHeader",
      "property": "spacing.before",
      "steps": [200, 150, 130]
    },
    {
      "id": "jobBefore",
      "target": "jobHeader",
      "property": "spacing.before",
      "steps": [140, 110]
    },
    {
      "id": "removeSpacers",
      "target": "document",
      "property": "spacers",
      "steps": ["keep", "remove"]
    }
  ]
}
